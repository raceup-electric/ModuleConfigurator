cmake_minimum_required(VERSION 3.20)

## Instance selection --------

if(NOT DEFINED INSTANCE)
  if(DEFINED ENV{PICO_SDK_PATH} OR DEFINED ENV{PICO_BOARD} OR DEFINED ENV{PICO_PLATFORM})
    set(INSTANCE rp2350)
    message(STATUS "INSTANCE not set; defaulting to rp2350 due to PICO environment")
  else()
    message(FATAL_ERROR "Use -DINSTANCE=<posix|stm32h562rgt6|stm32h563vit6x|rp2350>")
  endif()
endif()

# Check if instance is an STM32 target
string(REGEX MATCH "^stm32" IS_STM32 ${INSTANCE})

if(IS_STM32)
  # Extract first 7 chars + "xx" to determine family (e.g., stm32h5 -> stm32h5xx)
  string(SUBSTRING ${INSTANCE} 0 7 FAMILY_PREFIX)
  set(FAMILY_DIR ${FAMILY_PREFIX}xx)
  set(INSTANCE_DIR ${CMAKE_SOURCE_DIR}/instances/stm32/${FAMILY_DIR}/${INSTANCE})
else()
  # Non-STM32 instances (e.g., posix)
  set(INSTANCE_DIR ${CMAKE_SOURCE_DIR}/instances/${INSTANCE})
endif()

if(NOT EXISTS ${INSTANCE_DIR}/CMakeLists.txt)
  message(FATAL_ERROR "Unknown INSTANCE='${INSTANCE}' - CMakeLists.txt not found")
endif()

if(INSTANCE STREQUAL "rp2350")
  include(${CMAKE_SOURCE_DIR}/instances/rp2350/toolchain.cmake)
endif()

# Include ASM so startup files (.s) are built and Reset_Handler is linked
project(multitarget_freertos LANGUAGES C CXX ASM)

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)
set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

set(FREERTOS_KERNEL_DIR
  "${CMAKE_SOURCE_DIR}/third_party/FreeRTOS-LTS/FreeRTOS/FreeRTOS-Kernel"
  CACHE PATH "FreeRTOS kernel directory"
)

include(${INSTANCE_DIR}/CMakeLists.txt)


## Addition of targets -----

add_library(freertos_config INTERFACE)
target_include_directories(freertos_config INTERFACE
  ${CMAKE_SOURCE_DIR}/include
)

target_compile_definitions(freertos_config INTERFACE
  ${PLATFORM_DEFS}
)

add_library(freertos_kernel STATIC
  ${FREERTOS_KERNEL_SOURCES}
  ${FREERTOS_PORT_SOURCES}
  ${FREERTOS_HEAP_FILE}
)

target_include_directories(freertos_kernel PUBLIC
  ${FREERTOS_KERNEL_DIR}/include
  ${FREERTOS_PORT_INCLUDE}
)

target_link_libraries(freertos_kernel PUBLIC
  freertos_config
)

if(INSTANCE STREQUAL "rp2350")
  if(TARGET pico_base_headers)
    target_link_libraries(freertos_kernel PUBLIC pico_base_headers)
  endif()
  if(TARGET hardware_clocks)
    target_link_libraries(freertos_kernel PUBLIC hardware_clocks)
  endif()
  if(TARGET hardware_exception)
    target_link_libraries(freertos_kernel PUBLIC hardware_exception)
  endif()
  if(TARGET hardware_sync)
    target_link_libraries(freertos_kernel PUBLIC hardware_sync)
  endif()
  if(TARGET pico_multicore)
    target_link_libraries(freertos_kernel PUBLIC pico_multicore)
  endif()
  if(TARGET pico_stdlib)
    target_link_libraries(freertos_kernel PUBLIC pico_stdlib)
  endif()
endif()

add_subdirectory(lib/drivers)
add_subdirectory(app)

# Link any platform-specific libraries to drivers
if(DEFINED DRIVERS_LINK_LIBRARIES)
  target_link_libraries(drivers PUBLIC
    ${DRIVERS_LINK_LIBRARIES}
  )
endif()

if(INSTANCE STREQUAL "rp2350")
  if(TARGET pico_stdlib)
    target_link_libraries(drivers PUBLIC pico_stdlib)
  endif()
  if(CMAKE_CXX_COMPILER_ID MATCHES "GNU|Clang")
    target_compile_options(drivers PRIVATE $<$<COMPILE_LANGUAGE:CXX>:-frtti>)
  endif()
endif()

add_executable(firmware
  ${FIRMWARE_SOURCES}
  ${PLATFORM_MAIN}
)

target_include_directories(firmware PUBLIC
  ${PLATFORM_MAIN_INCDIR}
)

target_link_libraries(firmware PRIVATE
  ${FIRMWARE_LINK_LIBRARIES}
  src
  freertos_kernel
)
